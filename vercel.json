{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.mp4", "use": "@vercel/static" },
    { "src": "*.mp3", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "Merch/*", "use": "@vercel/static" },
    { "src": "uploads/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
