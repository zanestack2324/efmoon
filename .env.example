# EF MOON — Environment Variables
# Copy this file to .env and fill in values (if needed).

# JWT Secret for admin auth (auto-generated if not set)
# JWT_SECRET=your-random-secret-string

# === Production Storage (Vercel KV) ===
# These are auto-set by Vercel when you create a KV store.
# Create at: https://vercel.com/dashboard/stores
# KV_REST_API_URL=https://...upstash.io/...
# KV_REST_API_TOKEN=...

# === File Uploads (Vercel Blob) ===
# Auto-set when you create a Blob store in Vercel dashboard.
# BLOB_READ_WRITE_TOKEN=...
